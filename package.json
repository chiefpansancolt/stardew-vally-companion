{
    "name": "stardew-valley-companion",
    "version": "0.1.0",
    "description": "A Stardew Valley progress tracker and companion app",
    "keywords": [
        "stardew-valley",
        "game-tracker",
        "nextjs",
        "react",
        "companion-app"
    ],
    "author": "chiefpansancolt",
    "license": "MIT",
    "private": true,
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "postinstall": "bash scripts/copy-game-assets.sh"
    },
    "dependencies": {
        "flowbite-react": "^0.12.17",
        "next": "^16.1.6",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-toastify": "^11.0.5",
        "stardew-valley-data": "^0.29.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@tailwindcss/postcss": "^4",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^25",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9.39.4",
        "eslint-config-next": "16.1.6",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "react-icons": "^5.6.0",
        "tailwindcss": "^4",
        "ts-node": "^10.9.2",
        "typescript": "^6"
    }
}
